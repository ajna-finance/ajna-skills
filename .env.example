AJNA_SKILLS_MODE=inspect
AJNA_RPC_URL_BASE=
# Optional fallback used when a network-specific RPC URL is not set.
# AJNA_RPC_URL=

# Required for execute-prepared and for signing prepared payloads.
# AJNA_SIGNER_PRIVATE_KEY=0x

# Optional chain-backed smoke test inputs.
# RUN_AJNA_CHAIN_TESTS=1
# AJNA_TEST_POOL_ADDRESS=0x

# Optional fork-backed execute test inputs.
# AJNA_BASE_FORK_URL=https://...
# AJNA_BASE_FORK_BLOCK_NUMBER=44450000
# AJNA_FORK_PORT=9545
# AJNA_TEST_POOL_ADDRESS=0x97dbbdba28df6d629bc17e0349bcb73d541ed041
# AJNA_TEST_BUCKET_INDEX=3232
# AJNA_TEST_FUND_AMOUNT_RAW=100000000
# AJNA_TEST_LEND_AMOUNT_WAD=100000000000000000000
# AJNA_TEST_BORROW_LIMIT_INDEX=5000
# AJNA_TEST_COLLATERAL_FUND_AMOUNT_RAW=50000000000000000000
# AJNA_TEST_COLLATERAL_AMOUNT_WAD=50000000000000000000
# AJNA_TEST_BORROW_AMOUNT_WAD=1000000000000000000
